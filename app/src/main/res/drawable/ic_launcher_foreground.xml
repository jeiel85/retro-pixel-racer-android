<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Neon Synthwave Sunset -->
    <path
        android:pathData="M 54,20 a 24,24 0 1,0 0,48 a 24,24 0 1,0 0,-48"
        android:fillAlpha="0.85">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="20"
                android:endX="54"
                android:endY="68"
                android:type="linear">
                <item android:offset="0" android:color="#FFFF007F"/>
                <item android:offset="1" android:color="#FFFF8C00"/>
            </gradient>
        </aapt:attr>
    </path>
    
    <!-- Perspective Winding Racing Road -->
    <!-- Left Border -->
    <path
        android:pathData="M 54,42 L 18,94"
        android:strokeColor="#FF00FFFF"
        android:strokeWidth="2.5" />
        
    <!-- Right Border -->
    <path
        android:pathData="M 54,42 L 90,94"
        android:strokeColor="#FF00FFFF"
        android:strokeWidth="2.5" />
        
    <!-- Center Dash lines -->
    <path
        android:pathData="M 54,44 L 54,50 M 54,56 L 54,64 M 54,72 L 54,82 M 54,90 L 54,94"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.5" />

    <!-- Cute Retro pixel-style Sports Racer Car outline -->
    <!-- Spoiler -->
    <path
        android:pathData="M 38,70 L 70,70"
        android:strokeColor="#FFFF0055"
        android:strokeWidth="3.0" />
    <path
        android:pathData="M 38,68 L 38,72 M 70,68 L 70,72"
        android:strokeColor="#FFFF0055"
        android:strokeWidth="1.5" />
        
    <!-- Main Chassis -->
    <path
        android:pathData="M 42,72 L 66,72 L 64,84 L 44,84 Z"
        android:fillColor="#FFFF1A1A"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.0" />
        
    <!-- Cabin Glass -->
    <path
        android:pathData="M 48,74 L 60,74 L 59,79 L 49,79 Z"
        android:fillColor="#FF00E6FF" />
        
    <!-- Left Tire -->
    <path
        android:pathData="M 39,78 L 43,78 L 43,84 L 39,84 Z"
        android:fillColor="#FF111111" />
        
    <!-- Right Tire -->
    <path
        android:pathData="M 65,78 L 69,78 L 69,84 L 65,84 Z"
        android:fillColor="#FF111111" />
</vector>
